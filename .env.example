# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/whatsapp_agent
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_agent

# OpenRouter AI
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-api-key-here

# Choose any model from openrouter.ai/models
# Popular options:
#   anthropic/claude-3.5-sonnet   (best quality, ~$3/M tokens)
#   anthropic/claude-3-haiku      (fast & cheap, ~$0.25/M tokens)
#   openai/gpt-4o                 (OpenAI alternative)
#   meta-llama/llama-3.1-70b-instruct  (free tier available)
OPENROUTER_MODEL=openai/gpt-4o-mini

# App info (shown in openrouter.ai usage dashboard)
APP_URL=http://localhost:3000
APP_NAME=WhatsApp AI Agent

# WhatsApp Configuration
# Get these from your Meta WhatsApp Business Account
WHATSAPP_TOKEN=your-whatsapp-api-token-here
WHATSAPP_PHONE_ID=your-phone-id-here
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id-here
WHATSAPP_API_VERSION=v18.0
WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-here

# Application Configuration
MAX_CONVERSATION_HISTORY=10
SENTIMENT_THRESHOLD=-0.5
ESCALATION_MESSAGE_THRESHOLD=5
ENABLE_ESCALATION=true

# Logging
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=5m
LOG_FILE_MAX_FILES=5d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# JWT Authentication
# Generate a secure random secret: openssl rand -base64 32
JWT_SECRET=your-random-secret-at-least-32-chars

# Dashboard URL for CORS
CLIENT_URL=https://your-dashboard-domain.com

# DB pool size — Render free tier max is 25 total connections
DB_POOL_MAX=5
